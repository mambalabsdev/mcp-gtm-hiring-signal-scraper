{
  "manifest_version": "0.3",
  "name": "mcp-gtm-hiring-signal-scraper",
  "version": "1.0.6",
  "description": "MCP server for GTM Hiring Signal Scraper. Detects GTM hiring activity from company career pages via Apify. Clay-ready output.",
  "author": {
    "name": "Mamba Labs"
  },
  "license": "MIT",
  "homepage": "https://github.com/mambalabsdev/mcp-gtm-hiring-signal-scraper",
  "repository": {
    "type": "git",
    "url": "https://github.com/mambalabsdev/mcp-gtm-hiring-signal-scraper"
  },
  "server": {
    "type": "node",
    "entry_point": "build/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/build/index.js"
      ],
      "env": {
        "APIFY_TOKEN": "${user_config.apify_token}"
      }
    }
  },
  "user_config": {
    "apify_token": {
      "type": "string",
      "title": "Apify API Token",
      "description": "Apify API token for running the actor",
      "sensitive": true,
      "required": false
    }
  }
}
